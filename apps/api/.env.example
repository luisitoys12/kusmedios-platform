# Copy to .env and fill in values
# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# App
PORT=3001
NODE_ENV=production

# Database (when moving off in-memory)
DATABASE_URL=postgresql://user:password@host:5432/kusmedios

# CORS
CORS_ORIGIN=https://kusmedios-web.fly.dev
