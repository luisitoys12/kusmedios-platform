# === APP ===
NODE_ENV=development
APP_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3001
API_URL=http://localhost:4000

# === DATABASE (PostgreSQL / Neon) ===
DATABASE_URL=postgresql://user:password@localhost:5432/kusmedios

# === AUTH ===
JWT_SECRET=change_me_super_secret_jwt_key
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === REDIS ===
REDIS_URL=redis://localhost:6379

# === STORAGE (Cloudflare R2 / S3-compatible) ===
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=kusmedios
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=https://assets.estacionkusmedios.org

# === RADIO ENGINE ===
RADIO_ENGINE_URL=http://localhost:8000
AZURACAAST_API_KEY=
AZURACAAST_BASE_URL=http://localhost:8080/api

# === VIDEO ENGINE ===
RTMP_SERVER=rtmp://localhost:1935/live
HLS_BASE_URL=http://localhost:8080/hls
FFMPEG_PATH=/usr/bin/ffmpeg

# === SMTP ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@estacionkusmedios.org

# === STRIPE / PAGOS ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
OPENPAYFACTURA_KEY=

# === WEBSOCKET ===
WS_PORT=4001
